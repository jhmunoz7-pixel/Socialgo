# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canva Connect API — OAuth per-user (recommended)
# Register an integration at https://www.canva.com/developers/apps and copy
# the Client ID / Client Secret below. Set the Redirect URI in the Canva
# developer console to match CANVA_REDIRECT_URI.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
# Either set this explicitly, or it will be derived from NEXT_PUBLIC_APP_URL
# as `${NEXT_PUBLIC_APP_URL}/api/canva/auth/callback` automatically.
CANVA_REDIRECT_URI=

# OpenAI (optional — for AI image generation via DALL-E 3)
# Without this, the "Generar IA" button in the calendario drawer will
# return a 503 with a friendly "no configurado" message instead of
# breaking the UI. Images are rate-limited to 10 per user per hour.
OPENAI_API_KEY=

# Canva Connect API — legacy org-wide token (optional, deprecated)
# Used as a fallback for users who have not yet connected their own Canva
# account via the OAuth flow. Safe to leave empty once everyone has
# connected via Settings → Integraciones.
CANVA_API_TOKEN=

# Optional secret for manually triggering /api/cron/publish-scheduled
# outside of Vercel's scheduled invocations (they're trusted automatically).
# Generate a long random string.
CRON_SECRET=

# Optional: For local development with Supabase CLI
# SUPABASE_DB_PASSWORD=your_local_db_password
